#!/bin/bash

# --- Guardian Security Suite: Remote Sync Tool ---

# 1. Check if we are in a git repo
if [ ! -d .git ]; then
    echo "❌ Error: This directory is not a Git repository."
    exit 1
fi

echo "🛡️  Guardian Suite: Preparing update..."

# 2. Add all changes (scripts, install files, CVE lists)
git add .

# 3. Prompt for a commit message
# If you just hit Enter, it defaults to a timestamped message
read -p "Enter commit message (default: Update $(date +%F_%T)): " msg
if [ -z "$msg" ]; then
    msg="Update $(date +%F_%T)"
fi

# 4. Commit the changes
git commit -m "$msg"

# 5. Push to GitHub
echo "🚀 Pushing to GitHub..."
git push origin main

if [ $? -eq 0 ]; then
    echo -e "\e[1;32m✅ Guardian Suite successfully updated on GitHub!\e[0m"
else
    echo -e "\e[1;31m❌ Push failed. Check your network or credentials.\e[0m"
fi
